{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "target": "ES2021",
    "allowJs": true,
    "noImplicitAny": false,
    "moduleResolution": "bundler",
    "importHelpers": false,
    "isolatedModules": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2021", "DOM"]
  },
  "include": ["src/**/*.ts", "../core/**/*.js"]
}
